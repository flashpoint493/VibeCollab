# Symbology configuration template - docs/symbology.yaml
kind: symbology
version: "1"
updated_at: "{{ today }}"

# Unified symbol system for communication consistency
symbols:
  status:
    - symbol: "[x]"
      meaning: "Done / Completed"
    - symbol: "[ ]"
      meaning: "Not started / Todo"
    - symbol: "[!]"
      meaning: "Warning / Attention needed"
    - symbol: "[?]"
      meaning: "Question / Needs clarification"
    - symbol: "[~]"
      meaning: "In progress / Partial"
    - symbol: "[-]"
      meaning: "Skipped / N/A"

  priority:
    - symbol: "[P0]"
      meaning: "Critical - Must fix immediately"
    - symbol: "[P1]"
      meaning: "High - Fix in current iteration"
    - symbol: "[P2]"
      meaning: "Medium - Schedule for next iteration"
    - symbol: "[P3]"
      meaning: "Low - Fix when convenient"

  roles:
    - symbol: "[PM]"
      meaning: "Product Manager perspective"
    - symbol: "[ARCH]"
      meaning: "Architect perspective"
    - symbol: "[DEV]"
      meaning: "Developer perspective"
    - symbol: "[QA]"
      meaning: "Quality Assurance perspective"
    - symbol: "[UX]"
      meaning: "User Experience perspective"

  decision_levels:
    - symbol: "[S]"
      meaning: "Strategic - Architect+PM required"
    - symbol: "[A]"
      meaning: "Architectural - ARCH decides"
    - symbol: "[B]"
      meaning: "Implementation - DEV decides"
    - symbol: "[C]"
      meaning: "Trivial - Anyone decides"

  communication:
    - symbol: "=>"
      meaning: "Leads to / Results in"
    - symbol: "<->"
      meaning: "Bidirectional relationship"
    - symbol: "->"
      meaning: "Flow direction"
    - symbol: "|"
      meaning: "Alternative / Or"
    - symbol: "..."
      meaning: "And so on / Continues"

# Symbol usage guidelines
usage_guidelines:
  - "Use status symbols in checklists and progress tracking"
  - "Use priority symbols in task descriptions"
  - "Use role symbols to indicate perspective in discussions"
  - "Use decision level symbols in decision records"
  - "Combine symbols for clarity: [x][P0] means completed critical task"
