# Quick Reference configuration template - docs/quick_reference.yaml
kind: quick_reference
version: "1"
updated_at: "{{ today }}"

# Quick Reference Cards
starting_dialogue:
  title: "Starting a New Dialogue"
  template: |
    Continue project development.
    Please read CONTRIBUTING_AI.md and docs/CONTEXT.md to restore context first.
    Goal for this dialogue: {your goal}

ending_dialogue:
  title: "Before Ending a Dialogue"
  template: |
    Please update docs/CONTEXT.md to save current progress.
    Summarize the decisions and outputs of this dialogue.
    Then git commit to record this dialogue.

protocol_check:
  title: "Protocol Self-Check Trigger"
  commands:
    - "check protocol"
    - "protocol check"
    - "vibecollab check"

vibe_check:
  title: "Vibe Check"
  questions:
    - "Before continuing, let's confirm:"
    - "Are we aligned in understanding?"
    - "Is this the right direction?"
    - "Is there anything I haven't considered?"

# Common Commands Reference
common_commands:
  - command: "vibecollab check"
    description: "Check protocol compliance"
  - command: "vibecollab onboard"
    description: "AI onboarding guide"
  - command: "vibecollab next"
    description: "Action suggestions"
  - command: "vibecollab role whoami"
    description: "View current developer identity"
  - command: "vibecollab insight list"
    description: "List all insights"
  - command: "vibecollab task list"
    description: "List all tasks"

# Key Files Reference
key_files:
  - file: "CONTRIBUTING_AI.md"
    purpose: "Collaboration rules and protocols"
  - file: "docs/CONTEXT.md"
    purpose: "Current project state"
  - file: "docs/DECISIONS.md"
    purpose: "Confirmed and pending decisions"
  - file: "docs/ROADMAP.md"
    purpose: "Milestones and planning"
  - file: "docs/CHANGELOG.md"
    purpose: "Session outputs and progress"
  - file: "project.yaml"
    purpose: "Project configuration"
