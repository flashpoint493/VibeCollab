# Decision Levels configuration template - docs/decision_levels.yaml
kind: decision_levels
version: "1"
updated_at: "{{ today }}"

# Decision Classification System
decision_levels:
{% for level in decision_levels %}
  - level: "{{ level.level }}"
    name: "{{ level.name }}"
    scope: "{{ level.scope }}"
    review: "{{ level.review | format_review if level.review is mapping else level.review }}"
{% endfor %}
{% if not decision_levels %}
  - level: "S"
    name: "Strategic"
    scope: "Architecture direction, tech stack"
    review: "ARCH+PM required"
  - level: "A"
    name: "Architectural"
    scope: "Module design, interface contracts"
    review: "ARCH decides"
  - level: "B"
    name: "Implementation"
    scope: "Code structure, algorithms"
    review: "DEV decides"
  - level: "C"
    name: "Trivial"
    scope: "Naming, formatting"
    review: "Anyone decides"
{% endif %}

# Decision Record Format Template
decision_record_template:
  id: "DECISION-{number}"
  title: "{title}"
  level: "S/A/B/C"
  role: "[role code]"
  problem: "{the issue requiring a decision}"
  options:
    - "A: {option A}"
    - "B: {option B}"
  decision: "{final choice}"
  rationale: "{why this was chosen}"
  date: "{YYYY-MM-DD}"
  status: "PENDING/CONFIRMED/REVISED"
  related_tasks: []

# Decision Quality Principle
quality_principle:
  target_rate: 0.9
  critical_tolerance: 0
  description: "Many decisions, 90% accuracy, zero tolerance for critical mistakes"
  sa_level_requires: "human-AI co-review"
