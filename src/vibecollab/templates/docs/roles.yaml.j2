# Roles configuration template - docs/roles.yaml
kind: roles
version: "1"
updated_at: "{{ today }}"

# Role definitions for multi-role collaboration
roles:
{% for role in roles %}
  - code: "{{ role.code }}"
    name: "{{ role.name }}"
    focus:
{% for f in role.focus %}
      - "{{ f }}"
{% endfor %}
    triggers:
{% for t in role.triggers %}
      - "{{ t }}"
{% endfor %}
    is_gatekeeper: {{ role.is_gatekeeper | default(false) }}
    description: "{{ role.description | default('') }}"
{% endfor %}

# Gatekeeper role (if any)
gatekeeper: {{ roles | selectattr('is_gatekeeper', 'true') | map(attribute='code') | first | default('QA') }}

# Default role for single-developer mode
default_role: dev
