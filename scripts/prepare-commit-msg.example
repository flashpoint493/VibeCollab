#!/bin/bash
# VibeCollab Prepare Commit Message Hook
# Suggests commit message prefix based on staged files

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# Skip if commit message is already provided (e.g., -m flag)
if [ "$COMMIT_SOURCE" = "message" ]; then
    exit 0
fi

# Get staged files
STAGED_FILES=$(git diff --cached --name-only)

# Detect commit type based on files changed
if echo "$STAGED_FILES" | grep -qE "^\.vibecollab/insights/"; then
    SUGGESTED_PREFIX="[VIBE]"
    REASON="Insight changes detected"
elif echo "$STAGED_FILES" | grep -qE "^docs/.*\.(md|txt)$"; then
    if echo "$STAGED_FILES" | grep -q "ROADMAP\|DECISIONS"; then
        SUGGESTED_PREFIX="[ARCH]"
        REASON="Architecture/planning docs changed"
    else
        SUGGESTED_PREFIX="[DOC]"
        REASON="Documentation changes detected"
    fi
elif echo "$STAGED_FILES" | grep -qE "^tests?/"; then
    SUGGESTED_PREFIX="[TEST]"
    REASON="Test files changed"
elif echo "$STAGED_FILES" | grep -qE "^src/|^lib/"; then
    if echo "$STAGED_FILES" | grep -q "config\|settings"; then
        SUGGESTED_PREFIX="[CONFIG]"
        REASON="Configuration changes"
    else
        SUGGESTED_PREFIX="[FEAT]"
        REASON="Source code changes detected"
    fi
fi

if [ -n "$SUGGESTED_PREFIX" ]; then
    echo ""
    echo "💡 Suggested commit prefix: $SUGGESTED_PREFIX"
    echo "   Reason: $REASON"
    echo ""
    echo "   Based on project.yaml rules:"
    echo "   - [FEAT]: Requires docs/CONTEXT.md, docs/CHANGELOG.md, docs/QA_TEST_CASES.md"
    echo "   - [FIX]:  Requires docs/CHANGELOG.md, docs/QA_TEST_CASES.md"
    echo "   - [DOC]:  Requires docs/ROADMAP.md, docs/CHANGELOG.md"
    echo "   - [CONFIG]: No docs required"
    echo ""
    echo "   Tip: Run 'vibecollab check --strict' before committing"
    echo ""
fi

exit 0
